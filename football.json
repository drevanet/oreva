import androidx.appcompat.app.AlertDialog;
import androidx.appcompat.app.AppCompatActivity;
import android.os.Bundle;

public class MainActivity extends AppCompatActivity {

    @Override
    protected void onCreate(Bundle savedInstanceState) {
        super.onCreate(savedInstanceState);
        setContentView(R.layout.activity_main);

        // Directly show the dialog when activity starts
        showMyAlertDialog();
    }

    // Private method to build and display the alert
    private void showMyAlertDialog() {
        // Use the [AlertDialog.Builder](https://developer.android.com/develop/ui/views/components/dialogs) class
        AlertDialog.Builder builder = new AlertDialog.Builder(this);
        
        builder.setTitle("Welcome")
               .setMessage("This alert appeared on activity startup.")
               .setCancelable(false) // Prevents closing by clicking outside
               .setPositiveButton("OK", (dialog, id) -> {
                   dialog.dismiss(); // Closes the dialog
               });

        // Create and show the dialog
        AlertDialog dialog = builder.create();
        dialog.show();
    }
}
