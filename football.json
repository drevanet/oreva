const express = require('express');
const axios = require('axios');
const cors = require('cors');
const app = express();

app.use(cors()); // Allow your React localhost to access this backend

app.get('/proxy-stream', async (req, res) => {
    try {
        const { url } = req.query; // Pass the target m3u8 URL as a query param
        if (!url) return res.status(400).send('URL is required');

        // Fetch the external stream with the required spoofed headers
        const response = await axios({
            method: 'get',
            url: url,
            responseType: 'stream',
            headers: {
                'Referer': 'https://the-required-external-referrer.com',
                'Origin': 'https://the-required-external-referrer.com',
                'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36'
            }
        });

        // Forward the content type headers (e.g., application/x-mpegURL)
        res.setHeader('Content-Type', response.headers['content-type']);
        
        // Pipe the video stream data directly to React
        response.data.pipe(res);
    } catch (error) {
        console.error('Proxy Error:', error.message);
        res.status(500).send('Error fetching stream');
    }
});

app.listen(5000, () => console.log('Proxy server running on port 5000'));




import React from 'react';
import ReactPlayer from 'react-player';

function VideoPlayer() {
  const targetM3u8 = 'https://external-video-provider.com';
  
  // Point to your local Node.js proxy server and encode the target URL
  const proxiedUrl = `http://localhost:5000/proxy-stream?url=${encodeURIComponent(targetM3u8)}`;

  return (
    <div style={{ width: '640px', height: '360px' }}>
      <ReactPlayer 
        url={proxiedUrl} 
        controls 
        playing
        width="100%"
        height="100%"
        config={{
          file: {
            forceHLS: true // Ensures the browser treats the proxied stream as HLS
          }
        }}
      />
    </div>
  );
}

export default VideoPlayer;

