const express = require('express');
const axios = require('axios');
const cors = require('cors');

const app = express();
app.use(cors());

app.get('/proxy-stream', async (req, res) => {
  const targetUrl = req.query.url; // e.g., http://example.com
  const refererUrl = req.query.referer; // e.g., http://example.com

  if (!targetUrl || !refererUrl) {
    return res.status(400).send('Missing URL or Referer');
  }

  try {
    const response = await axios.get(targetUrl, {
      headers: {
        'Referer': refererUrl,
        'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64)'
      },
      responseType: 'stream'
    });

    // Forward the content type and headers to the client
    res.writeHead(200, {
      'Content-Type': response.headers['content-type'] || 'video/mp2t',
      'Transfer-Encoding': 'chunked'
    });

    response.data.pipe(res);
  } catch (error) {
    res.status(500).send('Error fetching stream');
  }
});

app.listen(5000, () => {
  console.log('Proxy server running on http://localhost:5000');
});





import React from 'react';
import ReactPlayer from 'react-player';

const TsVideoPlayer = () => {
  const targetTsUrl = 'ENCODE_YOUR_TARGET_TS_URL_HERE';
  const refererServer = 'ENCODE_YOUR_REFERER_SERVER_HERE';

  // Build the proxied URL
  const proxiedUrl = `http://localhost:5000/proxy-stream?url=${encodeURIComponent(
    targetTsUrl
  )}&referer=${encodeURIComponent(refererServer)}`;

  return (
    <div className="player-wrapper">
      <ReactPlayer
        url={proxiedUrl}
        controls={true}
        width="100%"
        height="100%"
        config={{
          file: {
            forceVideo: true,
            attributes: {
              crossOrigin: 'anonymous'
            }
          }
        }}
      />
    </div>
  );
};

export default TsVideoPlayer;
