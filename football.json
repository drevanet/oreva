const express = require('express');
const axios = require('axios');
const { Parser } = require('m3u8-parser');

const app = express();
const PORT = 3000;

// Helper to convert relative URLs to absolute URLs
function getAbsoluteUrl(relative, base) {
    return new URL(relative, base).href;
}

// 1. Manifest Proxy and Parser Endpoint
app.get('/proxy/playlist.m3u8', async (req, res) => {
    const remoteUrl = req.query.url;
    if (!remoteUrl) return res.status(400).send('Missing "url" query parameter.');

    try {
        // Fetch the remote M3U8 content
        const response = await axios.get(remoteUrl, { responseType: 'text' });
        const manifestText = response.data;
        
        // Find the base URL of the remote stream
        const urlObj = new URL(remoteUrl);
        const baseUrl = urlObj.origin + urlObj.pathname.substring(0, urlObj.pathname.lastIndexOf('/') + 1);

        // Parse the M3U8 structure
        const parser = new Parser();
        parser.push(manifestText);
        parser.end();

        const manifest = parser.manifest;
        let modifiedManifest = manifestText;

        // Case A: Master Playlist (Contains references to other playlists)
        if (manifest.playlists && manifest.playlists.length > 0) {
            manifest.playlists.forEach(playlist => {
                const absoluteSubUrl = getAbsoluteUrl(playlist.uri, baseUrl);
                // Rewrite the sub-playlist URI to route back to this proxy
                const proxySubUrl = `http://localhost:${PORT}/proxy/playlist.m3u8?url=${encodeURIComponent(absoluteSubUrl)}`;
                modifiedManifest = modifiedManifest.replace(playlist.uri, proxySubUrl);
            });
        } 
        // Case B: Media Playlist (Contains references to actual .ts video segments)
        else if (manifest.segments && manifest.segments.length > 0) {
            manifest.segments.forEach(segment => {
                const absoluteSegmentUrl = getAbsoluteUrl(segment.uri, baseUrl);
                // Rewrite the segment URI to route back to the segment proxy endpoint
                const proxySegmentUrl = `http://localhost:${PORT}/proxy/segment.ts?url=${encodeURIComponent(absoluteSegmentUrl)}`;
                modifiedManifest = modifiedManifest.replace(segment.uri, proxySegmentUrl);
            });
        }

        // Set correct HLS content type and return the rewritten manifest
        res.setHeader('Content-Type', 'application/vnd.apple.mpegurl');
        res.setHeader('Access-Control-Allow-Origin', '*'); // Bypass CORS
        res.send(modifiedManifest);

    } catch (error) {
        console.error('Error parsing M3U8:', error.message);
        res.status(500).send('Failed to parse or proxy the stream.');
    }
});

// 2. Video Segment (.ts) Proxy Endpoint
app.get('/proxy/segment.ts', async (req, res) => {
    const segmentUrl = req.query.url;
    if (!segmentUrl) return res.status(400).send('Missing "url" query parameter.');

    try {
        // Request the segment as a binary stream
        const streamResponse = await axios({
            method: 'get',
            url: segmentUrl,
            responseType: 'stream'
        });

        // Forward headers and pipe the video data back to the client
        res.setHeader('Content-Type', 'video/MP2T');
        res.setHeader('Access-Control-Allow-Origin', '*');
        streamResponse.data.pipe(res); // Memory efficient streaming

    } catch (error) {
        console.error('Error proxying segment:', error.message);
        res.status(500).send('Failed to fetch video segment.');
    }
});

app.listen(PORT, () => {
    console.log(`M3U8 Proxy Server running on http://localhost:${PORT}`);
});
