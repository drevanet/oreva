db.collection("your_collection")
  .addSnapshotListener((value, error) -> {
      if (error != null) return;

      for (DocumentChange dc : value.getDocumentChanges()) {
          switch (dc.getType()) {
              case ADDED:
                  yourArrayList.add(dc.getDocument().toObject(YourModelClass.class));
                  break;
              case MODIFIED:
                  // Handle the update by replacing the old item with the new one
                  int index = getIndexById(dc.getDocument().getId()); 
                  if (index != -1) {
                      yourArrayList.set(index, dc.getDocument().toObject(YourModelClass.class));
                  }
                  break;
              case REMOVED:
                  yourArrayList.remove(dc.getDocument().toObject(YourModelClass.class));
                  break;
          }
      }
      adapter.notifyDataSetChanged();
  });

db.collection("your_collection")
    .addSnapshotListener(new EventListener<QuerySnapshot>() {
        @Override
        public void onEvent(@Nullable QuerySnapshot snapshots, @Nullable FirebaseFirestoreException error) {
            if (error != null) return;

            for (DocumentChange dc : snapshots.getDocumentChanges()) {
                YourModel model = dc.getDocument().toObject(YourModel.class);
                
                switch (dc.getType()) {
                    case ADDED:
                        yourDataList.add(model);
                        adapter.notifyItemInserted(yourDataList.size() - 1);
                        break;
                    case MODIFIED:
                        // Find the index of the modified item and update it
                        int index = getIndexById(model); 
                        if (index != -1) {
                            yourDataList.set(index, model);
                            adapter.notifyItemChanged(index);
                        }
                        break;
                    case REMOVED:
                        int removeIndex = getIndexById(model);
                        if (removeIndex != -1) {
                            yourDataList.remove(removeIndex);
                            adapter.notifyItemRemoved(removeIndex);
                        }
                        break;
                }
            }
        }
    });



