// npm install express axios cors
const express = require('express');
const axios = require('axios');
const cors = require('cors');

const app = express();
const PORT = process.env.PORT || 5000;

// Enable CORS so your React app can communicate with this server
app.use(cors());

// Proxy endpoint
app.get('/api/proxy', async (req, res) => {
    const { targetUrl, referrer } = req.query;

    // Validate input parameters
    if (!targetUrl) {
        return res.status(400).json({ error: 'Missing targetUrl parameter' });
    }

    try {
        // Configure headers to mimic the allowed origin
        const headers = {
            'User-Agent': 'Mozilla/5.0 (Windows NT 10.0; Win64; x64) AppleWebKit/537.36',
        };

        if (referrer) {
            headers['Referer'] = referrer;
            headers['Origin'] = new URL(referrer).origin;
        }

        // Request the restricted content from the target server
        const response = await axios({
            method: 'GET',
            url: targetUrl,
            headers: headers,
            responseType: 'stream', // Streams data directly to save memory
            timeout: 10000 // 10-second timeout
        });

        // Forward the content type header (e.g., video/mp4, application/x-mpegURL)
        if (response.headers['content-type']) {
            res.setHeader('Content-Type', response.headers['content-type']);
        }
        
        if (response.headers['content-length']) {
            res.setHeader('Content-Length', response.headers['content-length']);
        }

        // Pipe the incoming data stream straight to the React client
        response.data.pipe(res);

    } catch (error) {
        console.error('Proxy Error:', error.message);
        res.status(error.response?.status || 500).json({ 
            error: 'Failed to fetch restricted content', 
            details: error.message 
        });
    }
});

app.listen(PORT, () => {
    console.log(`Proxy server running on port ${PORT}`);
});
import React, { useState } from 'react';

function App() {
  // Example state for the URLs
  const [videoUrl, setVideoUrl] = useState('https://restricted-website.com');
  const [referrerUrl, setReferrerUrl] = useState('https://allowed-referrer.com');
  const [proxyStreamUrl, setProxyStreamUrl] = useState('');

  const handlePlay = (e) => {
    e.preventDefault();

    if (!videoUrl) return alert('Please enter a video URL');

    // Base URL of your Node.js backend
    const proxyBase = 'http://localhost:5000/api/proxy';

    // Safely encode components to handle special characters (? and &) in URLs
    const encodedTarget = encodeURIComponent(videoUrl);
    const encodedReferrer = encodeURIComponent(referrerUrl);

    // Construct the final proxy string
    const finalUrl = `${proxyBase}?targetUrl=${encodedTarget}&referrer=${encodedReferrer}`;
    
    setProxyStreamUrl(finalUrl);
  };

  return (
    <div style={{ padding: '20px', fontFamily: 'sans-serif', maxWidth: '600px', margin: '0 auto' }}>
      <h2>Restricted Content Proxy Player</h2>
      
      <form onSubmit={handlePlay} style={{ display: 'flex', flexDirection: 'column', gap: '10px', marginBottom: '20px' }}>
        <div>
          <label style={{ display: 'block', fontWeight: 'bold' }}>Target Video URL:</label>
          <input 
            type="text" 
            value={videoUrl} 
            onChange={(e) => setVideoUrl(e.target.value)} 
            style={{ width: '100%', padding: '8px', marginTop: '4px' }}
            placeholder="https://example.com"
          />
        </div>

        <div>
          <label style={{ display: 'block', fontWeight: 'bold' }}>Required Referrer:</label>
          <input 
            type="text" 
            value={referrerUrl} 
            onChange={(e) => setReferrerUrl(e.target.value)} 
            style={{ width: '100%', padding: '8px', marginTop: '4px' }}
            placeholder="https://allowed-domain.com"
          />
        </div>

        <button type="submit" style={{ padding: '10px', background: '#007BFF', color: 'white', border: 'none', cursor: 'pointer', fontWeight: 'bold' }}>
          Load Media via Proxy
        </button>
      </form>

      {proxyStreamUrl && (
        <div>
          <h3>Player Output</h3>
          <video 
            src={proxyStreamUrl} 
            controls 
            autoPlay
            style={{ width: '100%', backgroundColor: '#000', borderRadius: '4px' }}
          >
            Your browser does not support the video tag.
          </video>
          <p style={{ fontSize: '12px', color: '#666', wordBreak: 'break-all', marginTop: '8px' }}>
            <strong>Streaming from:</strong> {proxyStreamUrl}
          </p>
        </div>
      )}
    </div>
  );
}

export default App;
