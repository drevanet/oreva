import React, { useState, useRef } from 'react';
import ReactPlayer from 'react-player';

const BlockedMediaViewer = () => {
  const [inputUrl, setInputUrl] = useState('');
  const [inputReferer, setInputReferer] = useState('');
  const [streamUrl, setStreamUrl] = useState('');
  const [isPlaying, setIsPlaying] = useState(false);
  const playerRef = useRef(null);

  const handlePlay = () => {
    if (!inputUrl) return;
    // Route the player through the Node.js proxy and pass referer as query params
    const proxyEndpoint = `http://localhost:5000/stream?url=${encodeURIComponent(inputUrl)}&referer=${encodeURIComponent(inputReferer)}`;
    setStreamUrl(proxyEndpoint);
    setIsPlaying(true);
  };

  return (
    <div className="flex flex-col items-center min-h-screen bg-gray-950 text-white p-6">
      <h1 className="text-2xl font-bold mb-6">Secure Media Player</h1>

      {/* Custom Inputs */}
      <div className="w-full max-w-2xl bg-gray-900 p-6 rounded-xl shadow-lg mb-8 space-y-4">
        <div>
          <label className="block text-sm font-medium mb-1">Media URL</label>
          <input
            type="text"
            className="w-full px-4 py-2 bg-gray-800 rounded border border-gray-700 focus:outline-none focus:border-blue-500"
            placeholder="https://example.com"
            value={inputUrl}
            onChange={(e) => setInputUrl(e.target.value)}
          />
        </div>
        <div>
          <label className="block text-sm font-medium mb-1">Referer Header URL</label>
          <input
            type="text"
            className="w-full px-4 py-2 bg-gray-800 rounded border border-gray-700 focus:outline-none focus:border-blue-500"
            placeholder="https://allowed-website.com"
            value={inputReferer}
            onChange={(e) => setInputReferer(e.target.value)}
          />
        </div>
        <button
          onClick={handlePlay}
          className="w-full py-2 px-4 bg-blue-600 hover:bg-blue-700 rounded-lg font-semibold transition"
        >
          Stream Media
        </button>
      </div>

      {/* Video Player Container */}
      {streamUrl && (
        <div className="w-full max-w-2xl aspect-video rounded-xl overflow-hidden shadow-2xl border border-gray-800">
          <ReactPlayer
            ref={playerRef}
            url={streamUrl}
            width="100%"
            height="100%"
            controls={true}
            playing={isPlaying}
            config={{
              file: {
                forceVideo: true,
              }
            }}
          />
        </div>
      )}
    </div>
  );
};

export default BlockedMediaViewer;
